# ---------------------------------------------------------------------------
# OPEN STORE — Supabase configuration (optional but recommended for GitHub → Vercel)
#
# Set these two variables and every visitor gets a working store, on any device,
# with no config.json and no setup wizard. Next.js inlines NEXT_PUBLIC_* values
# into the build, so they must be present when the site is BUILT (a redeploy
# picks up changes).
#
# In Vercel:  Project → Settings → Environment Variables → add both → Redeploy.
# Locally:    copy this file to `.env.local` and fill in your values.
#
# Find them in Supabase:  Project Settings → API
#   - Project URL     → NEXT_PUBLIC_SUPABASE_URL
#   - anon public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# The anon key is public by design (it ships in the browser bundle). Never put
# your service_role key here.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Optional: your site's public URL, used for shared-link previews (the
# thumbnail card shown on WhatsApp / Facebook / X). On Vercel this is detected
# automatically, so you usually don't need to set it. Set it only to override —
# e.g. when you use a custom domain:  NEXT_PUBLIC_SITE_URL=https://yourstore.com
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=
